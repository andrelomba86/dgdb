generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Docente {
  id                   Int             @id @default(autoincrement())
  nome                 String          @db.VarChar(100)
  endereco             String?         @db.VarChar(200)
  dataNascimento       DateTime?       @map("data_nascimento") @db.Date
  matricula            String?         @unique(map: "uq_docente_matricula") @db.VarChar(10)
  email                String?         @unique(map: "uq_docente_email") @db.VarChar(80)
  dataAdmissao         DateTime?       @map("data_admissao") @db.Date
  regimeJuridico       String?         @map("regime_juridico") @db.VarChar(15)
  regimeTrabalho       String?         @map("regime_trabalho") @db.VarChar(15)
  regimeDataAplicacao  DateTime?       @map("regime_data_aplicacao") @db.Date
  progressoes          Progressao[]
  telefones            Telefone[]
  documentos           Documento[]
  contasBancarias      ContaBancaria[]
  ativo                Boolean         @default(true)

  @@map("docente")
}

model Progressao {
  id          Int       @id @default(autoincrement())
  funcao      String?   @db.VarChar(60)
  dataInicio  DateTime? @map("data_inicio") @db.Date
  dataTermino DateTime? @map("data_termino") @db.Date
  referencia  String?   @db.VarChar(45)
  docenteId   Int       @map("docente_id")
  docente     Docente   @relation(fields: [docenteId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([docenteId], map: "fk_progressao_docente1_idx")
  @@map("progressao")
}

model Telefone {
  id        Int     @id @default(autoincrement())
  telefone  String  @db.VarChar(15)
  tipo      String  @db.VarChar(20)
  docenteId Int     @map("docente_id")
  docente   Docente @relation(fields: [docenteId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([docenteId, telefone], map: "uq_telefone_docente_numero")
  @@index([docenteId], map: "fk_telefone_docentes1_idx")
  @@map("telefone")
}

model Documento {
  id        Int     @id @default(autoincrement())
  tipo      String  @db.VarChar(25)
  documento String  @db.VarChar(45)
  docenteId Int     @map("docente_id")
  docente   Docente @relation(fields: [docenteId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([tipo, documento], map: "uq_documentos_tipo_numero")
  @@index([docenteId], map: "fk_documentos_docente1_idx")
  @@map("documentos")
}

model ContaBancaria {
  id        Int     @id @default(autoincrement())
  banco     String  @db.Char(3)
  agencia   String  @db.VarChar(8)
  conta     String  @db.VarChar(15)
  docenteId Int     @map("docente_id")
  docente   Docente @relation(fields: [docenteId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([docenteId, banco, agencia, conta], map: "uq_conta_bancaria_docente_conta")
  @@index([docenteId], map: "fk_conta_bancaria_docente1_idx")
  @@map("conta_bancaria")
}

model Usuario {
  id        Int      @id @default(autoincrement())
  login     String   @unique(map: "uq_usuario_login") @db.VarChar(80)
  nome      String   @db.VarChar(100)
  senhaHash String   @map("senha_hash") @db.VarChar(255)
  ativo     Boolean  @default(true)
  criadoEm  DateTime @map("criado_em") @default(now())
  atualizadoEm DateTime @map("atualizado_em") @updatedAt
  sessoes   Sessao[]

  @@map("usuario")
}

model Sessao {
  id          Int      @id @default(autoincrement())
  tokenHash   String   @map("token_hash") @unique(map: "uq_sessao_token_hash") @db.Char(64)
  expiraEm    DateTime @map("expira_em")
  ipOrigem    String?  @map("ip_origem") @db.VarChar(45)
  userAgent   String?  @map("user_agent") @db.VarChar(255)
  criadoEm    DateTime @map("criado_em") @default(now())
  usuarioId   Int      @map("usuario_id")
  usuario     Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([usuarioId], map: "fk_sessao_usuario_idx")
  @@index([expiraEm], map: "idx_sessao_expira_em")
  @@map("sessao")
}