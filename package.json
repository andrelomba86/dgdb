{
  "name": "dgdb",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "dev:e2e": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest --passWithNoTests",
    "test:ui": "vitest --ui --passWithNoTests",
    "test:unit": "vitest run tests/unit --passWithNoTests",
    "test:integration": "vitest run tests/integration --passWithNoTests",
    "test:integration:db": "node tests/integration/run-db-tests.mjs",
    "test:integration:db:local": "node tests/integration/run-db-tests.mjs --local",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "e2e": "playwright test --pass-with-no-tests",
    "e2e:ui": "playwright test --ui --pass-with-no-tests",
    "e2e:headed": "playwright test --headed --pass-with-no-tests",
    "e2e:install": "playwright install chromium",
    "test:ci": "npm run typecheck && npm run test:coverage && npm run test:integration && npm run e2e",
    "prisma:generate": "prisma generate",
    "prisma:format": "prisma format",
    "prisma:seed": "prisma db seed"
  },
  "dependencies": {
    "@chakra-ui/next-js": "^2.4.2",
    "@chakra-ui/react": "^3.3.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.9",
    "@mui/material": "^7.3.9",
    "@prisma/client": "^6.6.0",
    "bcrypt": "^5.1.1",
    "next": "^15.2.4",
    "pdf-lib": "^1.17.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^22.13.14",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "@vitest/coverage-v8": "^4.1.4",
    "@vitest/ui": "^4.1.4",
    "prisma": "^6.6.0",
    "testcontainers": "^11.14.0",
    "typescript": "^5.8.2",
    "vitest": "^4.1.4"
  },
  "prisma": {
    "seed": "node prisma/seed.mjs"
  }
}
